<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kama.jchatmind.mapper.AgentMemoryMapper">

    <resultMap id="BaseResultMap" type="com.kama.jchatmind.model.entity.AgentMemory">
        <id property="id" column="id" jdbcType="VARCHAR"/>
        <result property="agentId" column="agent_id" jdbcType="VARCHAR"/>
        <result property="sourceMessageId" column="source_message_id" jdbcType="VARCHAR"/>
        <result property="memoryScope" column="memory_scope" jdbcType="VARCHAR"/>
        <result property="memoryType" column="memory_type" jdbcType="VARCHAR"/>
        <result property="title" column="title" jdbcType="VARCHAR"/>
        <result property="content" column="content" jdbcType="VARCHAR"/>
        <result property="priority" column="priority" jdbcType="INTEGER"/>
        <result property="enabled" column="enabled" jdbcType="BOOLEAN"/>
        <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
        <result property="updatedAt" column="updated_at" jdbcType="TIMESTAMP"/>
        <result property="lastUsedAt" column="last_used_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,agent_id,source_message_id,memory_scope,
        memory_type,title,content,priority,
        enabled,created_at,updated_at,last_used_at
    </sql>

    <insert id="insert" parameterType="com.kama.jchatmind.model.entity.AgentMemory"
            keyColumn="id" keyProperty="id" useGeneratedKeys="true">
        INSERT INTO agent_memory
        (
            agent_id,
            source_message_id,
            memory_scope,
            memory_type,
            title,
            content,
            priority,
            enabled,
            created_at,
            updated_at,
            last_used_at
        )
        VALUES
            (
                CAST(#{agentId} AS uuid),
                <choose>
                    <when test="sourceMessageId != null">CAST(#{sourceMessageId} AS uuid)</when>
                    <otherwise>NULL</otherwise>
                </choose>,
                #{memoryScope},
                #{memoryType},
                #{title},
                #{content},
                #{priority},
                #{enabled},
                #{createdAt},
                #{updatedAt},
                #{lastUsedAt}
            )
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agent_memory
        WHERE id = CAST(#{id} AS uuid)
    </select>

    <select id="selectByAgentId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agent_memory
        WHERE agent_id = CAST(#{agentId} AS uuid)
        ORDER BY memory_scope ASC, priority DESC, updated_at DESC
    </select>

    <select id="selectEnabledByAgentId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agent_memory
        WHERE agent_id = CAST(#{agentId} AS uuid)
          AND enabled = TRUE
          AND memory_scope = 'core'
        ORDER BY priority DESC, updated_at DESC
        LIMIT #{limit}
    </select>

    <update id="updateById" parameterType="com.kama.jchatmind.model.entity.AgentMemory">
        UPDATE agent_memory
        <set>
            <if test="sourceMessageId != null">
                source_message_id = CAST(#{sourceMessageId} AS uuid),
            </if>
            <if test="memoryType != null">
                memory_type = #{memoryType},
            </if>
            <if test="memoryScope != null">
                memory_scope = #{memoryScope},
            </if>
            <if test="title != null">
                title = #{title},
            </if>
            <if test="content != null">
                content = #{content},
            </if>
            <if test="priority != null">
                priority = #{priority},
            </if>
            <if test="enabled != null">
                enabled = #{enabled},
            </if>
            <if test="lastUsedAt != null">
                last_used_at = #{lastUsedAt},
            </if>
            updated_at = NOW()
        </set>
        WHERE id = CAST(#{id} AS uuid)
    </update>

    <update id="markUsedByIds">
        UPDATE agent_memory
        SET last_used_at = NOW(),
            updated_at = updated_at
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            CAST(#{id} AS uuid)
        </foreach>
    </update>

    <delete id="deleteById">
        DELETE FROM agent_memory WHERE id = CAST(#{id} AS uuid)
    </delete>
</mapper>
