<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kama.jchatmind.mapper.UserMemoryMapper">

    <resultMap id="BaseResultMap" type="com.kama.jchatmind.model.entity.UserMemory">
        <id property="id" column="id" jdbcType="VARCHAR"/>
        <result property="userId" column="user_id" jdbcType="VARCHAR"/>
        <result property="sourceMessageId" column="source_message_id" jdbcType="VARCHAR"/>
        <result property="memoryType" column="memory_type" jdbcType="VARCHAR"/>
        <result property="title" column="title" jdbcType="VARCHAR"/>
        <result property="content" column="content" jdbcType="VARCHAR"/>
        <result property="priority" column="priority" jdbcType="INTEGER"/>
        <result property="confidence" column="confidence" jdbcType="DECIMAL"/>
        <result property="enabled" column="enabled" jdbcType="BOOLEAN"/>
        <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
        <result property="updatedAt" column="updated_at" jdbcType="TIMESTAMP"/>
        <result property="lastUsedAt" column="last_used_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,source_message_id,
        memory_type,title,content,priority,confidence,
        enabled,created_at,updated_at,last_used_at
    </sql>

    <insert id="insert" parameterType="com.kama.jchatmind.model.entity.UserMemory"
            keyColumn="id" keyProperty="id" useGeneratedKeys="true">
        INSERT INTO user_memory
        (
            user_id,
            source_message_id,
            memory_type,
            title,
            content,
            priority,
            confidence,
            enabled,
            created_at,
            updated_at,
            last_used_at
        )
        VALUES
            (
                <choose>
                    <when test="userId != null">CAST(#{userId} AS uuid)</when>
                    <otherwise>NULL</otherwise>
                </choose>,
                <choose>
                    <when test="sourceMessageId != null">CAST(#{sourceMessageId} AS uuid)</when>
                    <otherwise>NULL</otherwise>
                </choose>,
                #{memoryType},
                #{title},
                #{content},
                #{priority},
                #{confidence},
                #{enabled},
                #{createdAt},
                #{updatedAt},
                #{lastUsedAt}
            )
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_memory
        WHERE id = CAST(#{id} AS uuid)
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_memory
        ORDER BY priority DESC, updated_at DESC
    </select>

    <select id="selectEnabledGlobal" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_memory
        WHERE user_id IS NULL
          AND enabled = TRUE
        ORDER BY priority DESC, updated_at DESC
        LIMIT #{limit}
    </select>

    <update id="markUsedByIds">
        UPDATE user_memory
        SET last_used_at = NOW(),
            updated_at = updated_at
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            CAST(#{id} AS uuid)
        </foreach>
    </update>

    <update id="updateById" parameterType="com.kama.jchatmind.model.entity.UserMemory">
        UPDATE user_memory
        <set>
            <if test="memoryType != null">
                memory_type = #{memoryType},
            </if>
            <if test="title != null">
                title = #{title},
            </if>
            <if test="content != null">
                content = #{content},
            </if>
            <if test="priority != null">
                priority = #{priority},
            </if>
            <if test="confidence != null">
                confidence = #{confidence},
            </if>
            <if test="enabled != null">
                enabled = #{enabled},
            </if>
            <if test="lastUsedAt != null">
                last_used_at = #{lastUsedAt},
            </if>
            updated_at = NOW()
        </set>
        WHERE id = CAST(#{id} AS uuid)
    </update>

    <delete id="deleteById">
        DELETE FROM user_memory WHERE id = CAST(#{id} AS uuid)
    </delete>
</mapper>
